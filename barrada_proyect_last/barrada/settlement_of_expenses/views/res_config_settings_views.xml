<?xml version="1.0" encoding="utf-8"?>
<odoo>
     <!-- Settings: Diario de reintegro -->
    <record id="view_hr_expense_settings_reimbursement" model="ir.ui.view">
        <field name="name">hr.expense.settings.reimbursement</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="hr_expense.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <!-- Insertar después del campo 'expense_journal_id' -->
           <xpath expr="//field[@name='expense_journal_id']/ancestor::setting[1]" position="after">
                <setting company_dependent="1"
                     string="Expense Reimbursement Journal"
                     help="Default accounting journal for expense reimbursement.">
                  <field name="expense_reimbursement_journal_id"/>
                </setting>

           </xpath>
        </field>
    </record>

</odoo>