<odoo>
    <!-- 1. Definir la Acción que abre la vista -->
    <record id="action_gest_comercial" model="ir.actions.act_window">
        <field name="name">Gestion Comercial</field>
        <field name="res_model">hr.expense</field> <!-- El modelo que quieres ver -->
        <field name="view_mode">tree,form</field> <!-- Vista de lista y formulario -->
        <field name="domain">[]</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Crea tu primer gasto
            </p>
        </field>
    </record>

    <!-- 2. Definir el Menú Principal (Nivel Raíz) -->
    <!-- Al no poner atributo 'parent', aparece en la barra superior principal -->
    <menuitem id="menu_gest_comercial_root"
              name="Gestión Comercial"
              action="action_gest_comercial"
              sequence="50"/>


    <!-- 3. (Opcional) Submenús si necesitas organizar más -->
    <!-- <menuitem id="menu_mi_modulo_config" name="Configuración" parent="menu_mi_modulo_root" sequence="100"/> -->
</odoo>