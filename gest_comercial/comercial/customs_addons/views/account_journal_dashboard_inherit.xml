<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Heredar el dashboard de diarios contables -->
    <record id="account_journal_dashboard_kanban_view_inherit" model="ir.ui.view">
        <field name="name">account.account.journal.dashboard.kanban.inherit</field>
        <field name="model">account.journal</field>
        <field name="inherit_id" ref="account.account_journal_dashboard_kanban_view"/>
        <field name="arch" type="xml">

            <!-- OPCIÓN A: Agregar botones en el header del kanban -->
            <xpath expr="//div[@class='o_journal_dashboard']" position="inside">
                <div class="o_custom_dashboard_buttons" style="margin: 20px 0;">
                    <h3 class="text-center">Accesos Rápidos</h3>
                    <div class="row text-center">
                        <!-- Botón 1 -->
                        <div class="col-6 col-md-3 mb-3">
                            <button type="object"
                                    name="action_control_comercial"
                                    class="btn btn-primary btn-block"
                                    style="height: 100px;">
                                <i class="fa fa-file-invoice fa-2x mb-2"/>
                                <br/>
                                <span>Control Comercial</span>
                            </button>
                        </div>

                        <!-- Botón 2 -->
                        <div class="col-6 col-md-3 mb-3">
                            <button type="object"
                                    name="action_solicitud"
                                    class="btn btn-success btn-block"
                                    style="height: 100px;">
                                <i class="fa fa-money fa-2x mb-2"/>
                                <br/>
                                <span>Solicitud</span>
                            </button>
                        </div>

                        <!-- Botón 3 -->
                        <div class="col-6 col-md-3 mb-3">
                            <button type="object"
                                    name="action_contol_documentos"
                                    class="btn btn-info btn-block"
                                    style="height: 100px;">
                                <i class="fa fa-chart-line fa-2x mb-2"/>
                                <br/>
                                <span>Control de Documentos</span>
                            </button>
                        </div>

                        <!-- Botón 4 -->
                        <div class="col-6 col-md-3 mb-3">
                            <button type="object"
                                    name="action_p_entrega"
                                    class="btn btn-warning btn-block"
                                    style="height: 100px;">
                                <i class="fa fa-cog fa-2x mb-2"/>
                                <br/>
                                <span>Próxima Entrega</span>
                            </button>
                        </div>
                    </div>
                </div>
            </xpath>

        </field>
    </record>

    <!-- Acciones de ventana para cada botón -->
    <record id="action_control_comercial" model="ir.actions.act_window">
        <field name="name">Control Comercial</field>
        <field name="res_model">tu.modelo.1</field>
        <field name="view_mode">tree,form</field>
        <field name="target">current</field>
    </record>

    <record id="action_solicitud" model="ir.actions.act_window">
        <field name="name">Solicitud</field>
        <field name="res_model">tu.modelo.2</field>
        <field name="view_mode">tree,form</field>
        <field name="target">current</field>
    </record>

    <record id="action_contol_documentos" model="ir.actions.act_window">
        <field name="name">Control de Documentos</field>
        <field name="res_model">tu.modelo.3</field>
        <field name="view_mode">tree,form</field>
        <field name="target">current</field>
    </record>

    <record id="action_p_entrega" model="ir.actions.act_window">
        <field name="name">Próxima Entrega</field>
        <field name="res_model">tu.modelo.4</field>
        <field name="view_mode">tree,form</field>
        <field name="target">current</field>
    </record>
</odoo>